---
export interface Props {
  title: string;
  url: string;
  site: string;
  published: string;
  description: string;
  category: string;
}

const { title, url, site, published, description, category } = Astro.props;

// 公開時間を日本時間で表示用にフォーマット
const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return date.toLocaleString('ja-JP', {
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
};

// カテゴリ別の色設定
const getCategoryColor = (category: string) => {
  const colors = {
    'ビジネス': 'bg-blue-100 text-blue-800',
    'AI・技術': 'bg-green-100 text-green-800',
    'IT・技術': 'bg-purple-100 text-purple-800',
    '開発': 'bg-orange-100 text-orange-800',
    'クラウド': 'bg-indigo-100 text-indigo-800',
    'その他': 'bg-gray-100 text-gray-800'
  };
  return colors[category] || colors['その他'];
};
---

<article class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow duration-200 p-6 border border-gray-200">
  <div class="flex items-start justify-between mb-3">
    <div class="flex items-center space-x-2">
      <span class={`px-2 py-1 rounded-full text-xs font-medium ${getCategoryColor(category)}`}>
        {category}
      </span>
      <span class="text-sm text-gray-600 font-medium">{site}</span>
    </div>
    <time class="text-sm text-gray-500" datetime={published}>
      {formatDate(published)}
    </time>
  </div>
  
  <h2 class="text-lg font-semibold text-gray-900 mb-2 line-clamp-2">
    <a 
      href={url} 
      target="_blank" 
      rel="noopener noreferrer"
      class="hover:text-blue-600 transition-colors duration-200"
    >
      {title}
    </a>
  </h2>
  
  {description && (
    <p class="text-gray-700 text-sm line-clamp-3 leading-relaxed">
      {description}
    </p>
  )}
  
  <div class="mt-4 pt-3 border-t border-gray-100">
    <a 
      href={url} 
      target="_blank" 
      rel="noopener noreferrer"
      class="text-blue-600 hover:text-blue-800 text-sm font-medium flex items-center transition-colors duration-200"
    >
      記事を読む
      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
      </svg>
    </a>
  </div>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>