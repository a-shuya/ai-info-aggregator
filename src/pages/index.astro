---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import fs from 'fs';
import path from 'path';

// JSONデータの読み込み（タグ別ファイルから）
let articlesData;
try {
  const tagsDir = path.join(process.cwd(), 'data', 'tags');
  let allArticlesByDate = {
    '本日': [],
    '昨日': [],
    '一昨日': []
  };
  let totalArticles = 0;
  let lastUpdated = new Date().toISOString();
  
  // タグディレクトリが存在する場合
  if (fs.existsSync(tagsDir)) {
    const tagFiles = fs.readdirSync(tagsDir).filter(file => file.endsWith('.json'));
    
    for (const tagFile of tagFiles) {
      try {
        const tagPath = path.join(tagsDir, tagFile);
        const tagData = JSON.parse(fs.readFileSync(tagPath, 'utf-8'));
        
        if (tagData.articles_by_date) {
          // 各日付の記事をマージ
          Object.entries(tagData.articles_by_date).forEach(([dateKey, articles]) => {
            if (!allArticlesByDate[dateKey]) {
              allArticlesByDate[dateKey] = [];
            }
            allArticlesByDate[dateKey].push(...articles);
          });
          
          totalArticles += tagData.total_articles || 0;
          
          // 最新の更新時刻を取得
          if (tagData.last_updated && tagData.last_updated > lastUpdated) {
            lastUpdated = tagData.last_updated;
          }
        }
      } catch (tagError) {
        console.warn(`Failed to load tag file ${tagFile}:`, tagError);
      }
    }
  }
  
  articlesData = {
    last_updated: lastUpdated,
    total_articles: totalArticles,
    articles_by_date: allArticlesByDate
  };
  
} catch (error) {
  console.error('Failed to load articles data:', error);
  articlesData = {
    last_updated: new Date().toISOString(),
    total_articles: 0,
    articles_by_date: {
      '本日': [],
      '昨日': [],
      '一昨日': []
    }
  };
}

// 全記事を統合して日付とサイト別に分類
const allArticles = [];
Object.values(articlesData.articles_by_date).forEach(articles => {
  allArticles.push(...articles);
});

// サイト一覧を指定された順序で取得
const sites = [
  '日経ビジネス',
  'Business Insider(ビジネス)',
  'Business Insider(テック)',
  'Business Insider(サイエンス)',
  'Business Insider(スタートアップ)',
  '日経xTECH(IT)',
  'ITmedia(AI+)',
  'はてなブックマーク (IT)',
  'はてなブックマーク (AI)',
  'Zenn(機械学習)',
  'Zenn(AI)',
  'Zenn(生成 AI)',
  'Zenn(ディープラーニング)',
  'Zenn(LLM)',
  'Zenn(NLP)',
  'Zenn(Python)',
  'Zenn(Google Cloud)',
  'Cloud Blog',
  'Cloud Blog JA',
  'G-gen'
].filter(site => allArticles.some(article => article.site === site));

const formatLastUpdated = (dateString: string) => {
  const date = new Date(dateString);
  return date.toLocaleString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
};
---

<Layout title="AI情報収集ページ - 最新記事一覧">
  <div style="display: flex; min-height: 100vh;">
    <!-- 左サイドバー -->
    <div style="width: 250px; border-right: 1px solid #ddd; padding: 20px; background-color: #f9f9f9;">
      <h1 style="font-size: 18px; font-weight: bold; margin-bottom: 20px; text-align: center;">
        AI情報収集ページ
      </h1>
      
      <!-- 期間選択 -->
      <div style="margin-bottom: 20px;">
        <label style="display: block; font-size: 14px; font-weight: bold; margin-bottom: 5px;">期間選択:</label>
        <select id="periodSelector" style="width: 100%; padding: 5px; border: 1px solid #ddd; margin-bottom: 10px;">
          <option value="本日">本日</option>
          <option value="昨日">昨日</option>
          <option value="一昨日">一昨日</option>
          {Object.keys(articlesData.articles_by_date).filter(key => key.match(/^\d{4}-\d{2}$/)).map(month => (
            <option value={month}>{month}</option>
          ))}
        </select>
        <input type="date" id="dateSelector" style="width: 100%; padding: 5px; border: 1px solid #ddd; display: none;">
      </div>
      
      <!-- ナビゲーション -->
      <div style="border-bottom: 1px solid #ddd; margin-bottom: 20px;">
        <button class="nav-button" onclick="window.location.href='/home'" style="display: block; width: 100%; padding: 10px; border: none; background: none; text-align: left; cursor: pointer; border-bottom: 1px solid #eee;">
          市況・天気
        </button>
        <button class="nav-button active" style="display: block; width: 100%; padding: 10px; border: none; background: none; text-align: left; cursor: pointer; border-bottom: 2px solid black;">
          記事一覧
        </button>
      </div>
      
      <!-- タブ -->
      <div style="border-bottom: 1px solid #ddd; margin-bottom: 20px;">
        <button class="tab-button active" data-filter="all" style="display: block; width: 100%; padding: 10px; border: none; background: none; text-align: left; cursor: pointer; border-bottom: 2px solid black;">
          すべて
        </button>
        {sites.map(site => (
          <button class="tab-button" data-filter={site} style="display: block; width: 100%; padding: 10px; border: none; background: none; text-align: left; cursor: pointer; border-bottom: 1px solid #eee;">
            {site}
          </button>
        ))}
      </div>
      
      <!-- 統計 -->
      <div style="font-size: 12px; color: #666;">
        <p>最終更新: {formatLastUpdated(articlesData.last_updated)}</p>
        <p>総記事数: {articlesData.total_articles}件</p>
        <p>保存期間: 1年間</p>
        <div style="margin-top: 10px;">
          {Object.entries(articlesData.articles_by_date).map(([period, articles]) => (
            <p>{period}: {articles.length}件</p>
          ))}
        </div>
      </div>
    </div>

    <!-- メインコンテンツ -->
    <div style="flex: 1; padding: 20px;">
      <div id="articleContainer">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
          <h2 id="contentTitle" style="font-size: 20px; font-weight: bold; margin: 0;">本日のすべての記事</h2>
          <a id="siteLink" href="#" target="_blank" style="font-size: 14px; color: #0066cc; text-decoration: none; display: none;">
            元サイトを見る →
          </a>
        </div>
        <div id="articlesList">
          <!-- JavaScriptで動的に更新 -->
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ allArticles, sites, articlesData }}>
    // タブ切り替え機能
    const tabButtons = document.querySelectorAll('.tab-button');
    const articlesList = document.getElementById('articlesList');
    const contentTitle = document.getElementById('contentTitle');
    const dateSelector = document.getElementById('dateSelector');
    const periodSelector = document.getElementById('periodSelector');
    const siteLink = document.getElementById('siteLink');
    
    // サイトごとの元サイトリンク
    const siteLinks = {
      '日経ビジネス': 'https://business.nikkei.com/latest/?i_cid=nbpnb_latest',
      'Business Insider(ビジネス)': 'https://www.businessinsider.jp/business/',
      'Business Insider(テック)': 'https://www.businessinsider.jp/tech-news/',
      'Business Insider(サイエンス)': 'https://www.businessinsider.jp/science/',
      'Business Insider(スタートアップ)': 'https://www.businessinsider.jp/tag/start-up/',
      '日経xTECH(IT)': 'https://xtech.nikkei.com/top/it/',
      'ITmedia(AI+)': 'https://www.itmedia.co.jp/aiplus/',
      'はてなブックマーク (IT)': 'https://b.hatena.ne.jp/hotentry/it',
      'はてなブックマーク (AI)': 'https://b.hatena.ne.jp/entrylist/it/AI・機械学習',
      'Zenn(機械学習)': 'https://zenn.dev/topics/機械学習',
      'Zenn(AI)': 'https://zenn.dev/topics/ai',
      'Zenn(生成 AI)': 'https://zenn.dev/topics/生成ai',
      'Zenn(ディープラーニング)': 'https://zenn.dev/topics/deeplearning',
      'Zenn(LLM)': 'https://zenn.dev/topics/llm',
      'Zenn(NLP)': 'https://zenn.dev/topics/nlp',
      'Zenn(Python)': 'https://zenn.dev/topics/python',
      'Zenn(Google Cloud)': 'https://zenn.dev/topics/googlecloud',
      'Cloud Blog': 'https://cloud.google.com/blog?hl=en',
      'Cloud Blog JA': 'https://cloud.google.com/blog/ja',
      'G-gen': 'https://blog.g-gen.co.jp'
    };
    
    // 今日の日付を設定
    const today = new Date();
    dateSelector.value = today.toISOString().split('T')[0];
    
    let currentFilter = 'all';
    let currentPeriod = '本日';
    
    function createArticleHTML(article) {
      const formatDate = (dateString) => {
        const date = new Date(dateString);
        return date.toLocaleString('ja-JP', {
          timeZone: 'Asia/Tokyo',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
      };
      
      const getFaviconUrl = (url) => {
        try {
          const domain = new URL(url).hostname;
          return `https://www.google.com/s2/favicons?domain=${domain}&sz=32`;
        } catch {
          return '';
        }
      };
      
      return `
        <div class="article-card" onclick="window.open('${article.url}', '_blank')" style="
          border: 1px solid #ddd; 
          padding: 15px; 
          margin-bottom: 10px;
          cursor: pointer;
          transition: all 0.2s ease;
          border-radius: 8px;
          display: flex;
          flex-direction: column;
          position: relative;
        ">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <img src="${getFaviconUrl(article.url)}" alt="${article.site} favicon" style="
                width: 16px;
                height: 16px;
              " onerror="this.style.display='none';">
              <span style="font-size: 12px; color: #666;">${article.site}</span>
            </div>
            <span style="font-size: 12px; color: #666;">${formatDate(article.published)}</span>
          </div>
          
          <h3 style="font-size: 16px; font-weight: bold; margin-bottom: 8px; line-height: 1.4; color: black;">
            ${article.title}
          </h3>
          
          ${article.description ? `
            <p style="font-size: 14px; color: #666; margin-bottom: 8px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
              ${article.description}
            </p>
          ` : ''}
          
        </div>
      `;
    }
    
    function filterArticles() {
      let filteredArticles = [];
      let title = '';
      
      // 指定された期間の記事を表示
      filteredArticles = articlesData.articles_by_date[currentPeriod] || [];
      title = currentFilter === 'all' ? `${currentPeriod}のすべての記事` : `${currentPeriod}の${currentFilter}記事`;
      
      // サイトフィルタを適用
      if (currentFilter !== 'all') {
        filteredArticles = filteredArticles.filter(article => article.site === currentFilter);
      }
      
      contentTitle.textContent = title;
      
      // 元サイトリンクの表示制御
      if (currentFilter !== 'all' && siteLinks[currentFilter]) {
        siteLink.href = siteLinks[currentFilter];
        siteLink.style.display = 'block';
      } else {
        siteLink.style.display = 'none';
      }
      
      if (filteredArticles.length === 0) {
        articlesList.innerHTML = '<p style="color: #666; text-align: center; padding: 40px;">記事がありません</p>';
      } else {
        // PC版では3列、モバイルでは1列のグリッドレイアウト（左詰め配置）
        articlesList.innerHTML = `
          <div style="
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 400px));
            gap: 20px;
            max-width: 100%;
            justify-content: start;
          ">
            ${filteredArticles.map(createArticleHTML).join('')}
          </div>
        `;
        
        // 記事カードの最大幅制限とホバー効果を追加
        const articleCards = document.querySelectorAll('.article-card');
        articleCards.forEach(card => {
          // レイアウトバグ修正：最大幅制限
          card.style.maxWidth = '400px';
          
          // ホバー効果
          card.addEventListener('mouseenter', () => {
            card.style.transform = 'translateY(-2px)';
            card.style.boxShadow = '0 4px 12px rgba(0, 0, 0, 0.1)';
            card.style.borderColor = '#999';
          });
          
          card.addEventListener('mouseleave', () => {
            card.style.transform = 'translateY(0)';
            card.style.boxShadow = 'none';
            card.style.borderColor = '#ddd';
          });
        });
      }
    }
    
    // ナビゲーションボタンのホバー効果
    const navButtons = document.querySelectorAll('.nav-button');
    navButtons.forEach(button => {
      if (!button.classList.contains('active')) {
        button.addEventListener('mouseenter', () => {
          button.style.backgroundColor = '#f0f0f0';
        });
        button.addEventListener('mouseleave', () => {
          button.style.backgroundColor = '';
        });
      }
    });
    
    // タブクリックイベント
    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        tabButtons.forEach(btn => {
          btn.style.borderBottom = '1px solid #eee';
          btn.classList.remove('active');
        });
        
        button.style.borderBottom = '2px solid black';
        button.classList.add('active');
        
        currentFilter = button.dataset.filter;
        filterArticles();
      });
    });
    
    // 期間変更イベント
    periodSelector.addEventListener('change', () => {
      currentPeriod = periodSelector.value;
      filterArticles();
    });
    
    // 初期表示
    filterArticles();
  </script>
</Layout>