---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import fs from 'fs';
import path from 'path';

// JSONデータの読み込み（タグ別ファイルから）
let articlesData;
try {
  const tagsDir = path.join(process.cwd(), 'data', 'tags');
  let allArticlesByDate = {
    '本日': [],
    '昨日': [],
    '一昨日': []
  };
  let totalArticles = 0;
  let lastUpdated = new Date().toISOString();
  
  // タグディレクトリが存在する場合
  if (fs.existsSync(tagsDir)) {
    const tagFiles = fs.readdirSync(tagsDir).filter(file => file.endsWith('.json'));
    
    for (const tagFile of tagFiles) {
      try {
        const tagPath = path.join(tagsDir, tagFile);
        const tagData = JSON.parse(fs.readFileSync(tagPath, 'utf-8'));
        
        if (tagData.articles_by_date) {
          // 各日付の記事をマージ
          Object.entries(tagData.articles_by_date).forEach(([dateKey, articles]) => {
            if (!allArticlesByDate[dateKey]) {
              allArticlesByDate[dateKey] = [];
            }
            allArticlesByDate[dateKey].push(...articles);
          });
          
          totalArticles += tagData.total_articles || 0;
          
          // 最新の更新時刻を取得
          if (tagData.last_updated && tagData.last_updated > lastUpdated) {
            lastUpdated = tagData.last_updated;
          }
        }
      } catch (tagError) {
        console.warn(`Failed to load tag file ${tagFile}:`, tagError);
      }
    }
  }
  
  articlesData = {
    last_updated: lastUpdated,
    total_articles: totalArticles,
    articles_by_date: allArticlesByDate
  };
  
} catch (error) {
  console.error('Failed to load articles data:', error);
  articlesData = {
    last_updated: new Date().toISOString(),
    total_articles: 0,
    articles_by_date: {
      '本日': [],
      '昨日': [],
      '一昨日': []
    }
  };
}

// 全記事を統合して日付とサイト別に分類
const allArticles = [];
Object.values(articlesData.articles_by_date).forEach(articles => {
  allArticles.push(...articles);
});

// サイト一覧を固定リストで表示（期間に関係なく常に表示）
const sites = [
  '日経ビジネス',
  'Business Insider(ビジネス)',
  'Business Insider(テック)',
  'Business Insider(サイエンス)',
  '日経xTECH(IT)',
  'ITmedia(AI+)',
  'はてなブックマーク (IT)',
  'はてなブックマーク (AI)',
  'Zenn(機械学習)',
  'Zenn(AI)',
  'Zenn(生成 AI)',
  'Zenn(ディープラーニング)',
  'Zenn(LLM)',
  'Zenn(NLP)',
  'Zenn(Python)',
  'Zenn(Google Cloud)',
  'Cloud Blog',
  'Cloud Blog JA',
  'G-gen'
];

const formatLastUpdated = (dateString: string) => {
  const date = new Date(dateString);
  return date.toLocaleString('ja-JP', {
    timeZone: 'Asia/Tokyo',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
};
---

<Layout title="AI情報収集ページ - 最新記事一覧">
  <!-- モバイル用ヘッダー -->
  <div class="mobile-header" style="display: none; padding: 15px; background-color: #f9f9f9; border-bottom: 1px solid #ddd;">
    <h1 style="font-size: 18px; font-weight: bold; margin-bottom: 15px; text-align: center;">
      AI情報収集ページ
    </h1>
    
    <!-- モバイル用ナビゲーション -->
    <div style="display: flex; gap: 10px; margin-bottom: 15px;">
      <button class="mobile-nav-button" onclick="window.location.href='/home'" style="flex: 1; padding: 8px; border: 1px solid #ddd; background: white; cursor: pointer; border-radius: 4px;">
        市況・天気
      </button>
      <button class="mobile-nav-button active" style="flex: 1; padding: 8px; border: 1px solid #333; background: #333; color: white; cursor: pointer; border-radius: 4px;">
        記事一覧
      </button>
    </div>
    
    <!-- モバイル用日付選択 -->
    <div style="margin-bottom: 15px;">
      <label style="display: block; font-size: 14px; font-weight: bold; margin-bottom: 5px;">日付選択:</label>
      <input type="date" id="mobileDatePicker" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 16px;">
    </div>
    
    <!-- モバイル用タブ選択 -->
    <div>
      <select id="mobileTabSelector" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;">
        <option value="all">すべて</option>
        {sites.map(site => (
          <option value={site}>{site}</option>
        ))}
      </select>
    </div>
  </div>

  <div class="main-container" style="display: flex; min-height: 100vh;">
    <!-- PC用左サイドバー -->
    <div class="desktop-sidebar" style="width: 250px; min-width: 250px; flex-shrink: 0; border-right: 1px solid #ddd; padding: 20px; background-color: #f9f9f9;">
      <h1 style="font-size: 18px; font-weight: bold; margin-bottom: 20px; text-align: center;">
        AI情報収集ページ
      </h1>
      
      <!-- 日付選択 -->
      <div style="margin-bottom: 20px;">
        <label style="display: block; font-size: 14px; font-weight: bold; margin-bottom: 5px;">日付選択:</label>
        <input type="date" id="desktopDatePicker" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;">
      </div>
      
      <!-- ナビゲーション -->
      <div style="border-bottom: 1px solid #ddd; margin-bottom: 20px;">
        <button class="nav-button" onclick="window.location.href='/home'" style="display: block; width: 100%; padding: 10px; border: none; background: none; text-align: left; cursor: pointer; border-bottom: 1px solid #eee;">
          市況・天気
        </button>
        <button class="nav-button active" style="display: block; width: 100%; padding: 10px; border: none; background: none; text-align: left; cursor: pointer; border-bottom: 2px solid black;">
          記事一覧
        </button>
      </div>
      
      <!-- タブ -->
      <div style="border-bottom: 1px solid #ddd; margin-bottom: 20px;">
        <button class="tab-button active" data-filter="all" style="display: block; width: 100%; padding: 10px; border: none; background: none; text-align: left; cursor: pointer; border-bottom: 2px solid black;">
          すべて
        </button>
        {sites.map(site => (
          <button class="tab-button" data-filter={site} style="display: block; width: 100%; padding: 10px; border: none; background: none; text-align: left; cursor: pointer; border-bottom: 1px solid #eee;">
            {site}
          </button>
        ))}
      </div>
      
      <!-- 統計 -->
      <div style="font-size: 12px; color: #666;">
        <p>最終更新: {formatLastUpdated(articlesData.last_updated)}</p>
        <p>総記事数: {articlesData.total_articles}件</p>
        <p>保存期間: 1年間</p>
        <div style="margin-top: 10px;">
          {Object.entries(articlesData.articles_by_date).filter(([period]) => ['本日', '昨日', '一昨日'].includes(period)).map(([period, articles]) => (
            <p>{period}: {articles.length}件</p>
          ))}
        </div>
      </div>
    </div>

    <!-- メインコンテンツ -->
    <div class="main-content" style="flex: 1; padding: 20px; min-width: 0; max-width: calc(100vw - 270px); overflow: hidden; box-sizing: border-box;">
      <div id="articleContainer" style="width: 100%; max-width: 100%; overflow: hidden;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
          <h2 id="contentTitle" style="font-size: 20px; font-weight: bold; margin: 0;">本日のすべての記事</h2>
          <a id="siteLink" href="#" target="_blank" style="font-size: 14px; color: #0066cc; text-decoration: none; display: none;">
            元サイトを見る →
          </a>
        </div>
        <div id="articlesList">
          <!-- JavaScriptで動的に更新 -->
        </div>
      </div>
    </div>
  </div>

  <!-- モバイル用統計情報（下部） -->
  <div class="mobile-stats" style="display: none; padding: 15px; background-color: #f9f9f9; border-top: 1px solid #ddd; font-size: 12px; color: #666;">
    <p>最終更新: {formatLastUpdated(articlesData.last_updated)}</p>
    <p>総記事数: {articlesData.total_articles}件</p>
    <p>保存期間: 1年間</p>
    <div style="margin-top: 10px; display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 5px;">
      {Object.entries(articlesData.articles_by_date).filter(([period]) => ['本日', '昨日', '一昨日'].includes(period)).map(([period, articles]) => (
        <span>{period}: {articles.length}件</span>
      ))}
    </div>
  </div>

  <style>
    /* ボタンのホバー効果 */
    .nav-button:not(.active):hover {
      background-color: #f0f0f0;
    }
    
    .tab-button:not(.active):hover {
      background-color: #f0f0f0;
    }
    
    /* レスポンシブスタイル */
    @media (max-width: 1024px) {
      .mobile-header {
        display: block !important;
      }
      .desktop-sidebar {
        display: none !important;
      }
      .main-container {
        flex-direction: column !important;
      }
      .main-content {
        padding: 15px !important;
        max-width: 100vw !important;
        width: 100% !important;
      }
      .mobile-stats {
        display: block !important;
      }
      .articles-grid {
        grid-template-columns: 1fr !important;
        display: grid !important;
        gap: 15px !important;
        width: 100% !important;
        max-width: 100% !important;
      }
      #articleContainer {
        width: 100% !important;
        max-width: 100% !important;
      }
      .articles-grid .article-card {
        width: 100% !important;
        max-width: 100% !important;
      }
      .articles-grid > div[style*="visibility: hidden"] {
        display: none !important;
      }
    }
    
    @media (min-width: 1025px) {
      .mobile-header {
        display: none !important;
      }
      .mobile-stats {
        display: none !important;
      }
    }
    
  </style>

  <script define:vars={{ allArticles, sites, articlesData }}>
    // タブ切り替え機能
    const tabButtons = document.querySelectorAll('.tab-button');
    const articlesList = document.getElementById('articlesList');
    const contentTitle = document.getElementById('contentTitle');
    const siteLink = document.getElementById('siteLink');
    
    // 日付選択要素
    const desktopDatePicker = document.getElementById('desktopDatePicker');
    const mobileDatePicker = document.getElementById('mobileDatePicker');
    const mobileTabSelector = document.getElementById('mobileTabSelector');
    
    // サイトごとの元サイトリンク
    const siteLinks = {
      '日経ビジネス': 'https://business.nikkei.com/latest/?i_cid=nbpnb_latest',
      'Business Insider(ビジネス)': 'https://www.businessinsider.jp/business/',
      'Business Insider(テック)': 'https://www.businessinsider.jp/tech-news/',
      'Business Insider(サイエンス)': 'https://www.businessinsider.jp/science/',
      '日経xTECH(IT)': 'https://xtech.nikkei.com/top/it/',
      'ITmedia(AI+)': 'https://www.itmedia.co.jp/aiplus/',
      'はてなブックマーク (IT)': 'https://b.hatena.ne.jp/hotentry/it',
      'はてなブックマーク (AI)': 'https://b.hatena.ne.jp/entrylist/it/AI・機械学習',
      'Zenn(機械学習)': 'https://zenn.dev/topics/機械学習',
      'Zenn(AI)': 'https://zenn.dev/topics/ai',
      'Zenn(生成 AI)': 'https://zenn.dev/topics/生成ai',
      'Zenn(ディープラーニング)': 'https://zenn.dev/topics/deeplearning',
      'Zenn(LLM)': 'https://zenn.dev/topics/llm',
      'Zenn(NLP)': 'https://zenn.dev/topics/nlp',
      'Zenn(Python)': 'https://zenn.dev/topics/python',
      'Zenn(Google Cloud)': 'https://zenn.dev/topics/googlecloud',
      'Cloud Blog': 'https://cloud.google.com/blog?hl=en',
      'Cloud Blog JA': 'https://cloud.google.com/blog/ja',
      'G-gen': 'https://blog.g-gen.co.jp'
    };
    
    // 現在の状態
    let currentFilter = 'all';
    let currentDate = new Date(); // 現在選択されている日付
    
    // 日付選択範囲の設定
    const minDateStr = '2025-01-01';
    const maxDateStr = new Date().toISOString().split('T')[0]; // 本日まで
    
    function createArticleHTML(article) {
      const formatDate = (dateString) => {
        const date = new Date(dateString);
        return date.toLocaleString('ja-JP', {
          timeZone: 'Asia/Tokyo',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
      };
      
      const getFaviconUrl = (url) => {
        try {
          const domain = new URL(url).hostname;
          return `https://www.google.com/s2/favicons?domain=${domain}&sz=32`;
        } catch {
          return '';
        }
      };
      
      return `
        <div class="article-card" onclick="window.open('${article.url}', '_blank')" style="
          border: 1px solid #ddd; 
          padding: 15px; 
          margin-bottom: 10px;
          cursor: pointer;
          transition: all 0.2s ease;
          border-radius: 8px;
          display: flex;
          flex-direction: column;
          position: relative;
          word-wrap: break-word;
          overflow-wrap: break-word;
          min-width: 0;
          max-width: 100%;
          overflow: hidden;
          box-sizing: border-box;
        ">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <img src="${getFaviconUrl(article.url)}" alt="${article.site} favicon" style="
                width: 16px;
                height: 16px;
              " onerror="this.style.display='none';">
              <span style="font-size: 12px; color: #666;">${article.site}</span>
            </div>
            <span style="font-size: 12px; color: #666;">${formatDate(article.published)}</span>
          </div>
          
          <h3 style="font-size: 16px; font-weight: bold; margin-bottom: 8px; line-height: 1.4; color: black; word-wrap: break-word; overflow-wrap: break-word;">
            ${article.title}
          </h3>
          
          ${article.description ? `
            <p style="font-size: 14px; color: #666; margin-bottom: 8px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
              ${article.description}
            </p>
          ` : ''}
          
        </div>
      `;
    }
    
    // 日付キーのフォーマット（YYYY-MM-DD）
    function formatDateKey(date) {
      return date.toISOString().split('T')[0];
    }
    
    // 指定日付の記事を取得（日本時間ベース）
    function getArticlesForDate(dateStr) {
      return allArticles.filter(article => {
        try {
          // 記事の公開日時をUTC時刻として解析
          const articleDate = new Date(article.published);
          
          // 日本時間に変換
          const articleDateJST = new Date(articleDate.toLocaleString('en-US', { timeZone: 'Asia/Tokyo' }));
          
          // 選択された日付の範囲を日本時間で設定
          const selectedDate = new Date(dateStr);
          const startOfDayJST = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), selectedDate.getDate(), 0, 0, 0, 0);
          const endOfDayJST = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), selectedDate.getDate(), 23, 59, 59, 999);
          
          // 記事の日付が選択された日の範囲内かチェック
          return articleDateJST >= startOfDayJST && articleDateJST <= endOfDayJST;
        } catch {
          return false;
        }
      });
    }
    
    function filterArticles() {
      let filteredArticles = [];
      let title = '';
      
      // 選択された日付の記事を取得
      const dateStr = formatDateKey(currentDate);
      filteredArticles = getArticlesForDate(dateStr);
      
      // サイトフィルタを適用
      if (currentFilter !== 'all') {
        filteredArticles = filteredArticles.filter(article => article.site === currentFilter);
      }
      
      // 新着順でソート（新しい記事が上）
      filteredArticles.sort((a, b) => {
        const dateA = new Date(a.published);
        const dateB = new Date(b.published);
        return dateB - dateA; // 降順（新しい順）
      });
      
      // タイトル設定
      const displayDate = currentDate.toLocaleDateString('ja-JP');
      title = currentFilter === 'all' ? `${displayDate}のすべての記事` : `${displayDate}の${currentFilter}記事`;
      contentTitle.textContent = title;
      
      // 元サイトリンクの表示制御
      if (currentFilter !== 'all' && siteLinks[currentFilter]) {
        siteLink.href = siteLinks[currentFilter];
        siteLink.style.display = 'block';
      } else {
        siteLink.style.display = 'none';
      }
      
      if (filteredArticles.length === 0) {
        articlesList.innerHTML = '<p style="color: #666; text-align: center; padding: 40px;">記事がありません</p>';
      } else {
        // 3列固定レイアウト（レスポンシブ対応）
        const articlesHTML = filteredArticles.map(createArticleHTML).join('');
        
        // ダミーボックスを追加（3の倍数になるまで）
        const dummyBoxes = [];
        const remainder = filteredArticles.length % 3;
        if (remainder !== 0) {
          const dummyCount = 3 - remainder;
          for (let i = 0; i < dummyCount; i++) {
            dummyBoxes.push('<div style="visibility: hidden;"></div>');
          }
        }
        
        // 画面幅に応じてグリッドレイアウトを決定
        const isMobile = window.innerWidth <= 1024;
        const gridColumns = isMobile ? '1fr' : 'repeat(3, 1fr)';
        const gridGap = isMobile ? '15px' : '20px';
        
        articlesList.innerHTML = `
          <div style="
            display: grid;
            grid-template-columns: ${gridColumns};
            gap: ${gridGap};
            width: 100%;
            max-width: 100%;
            overflow: hidden;
            box-sizing: border-box;
          " class="articles-grid">
            ${articlesHTML}
            ${isMobile ? '' : dummyBoxes.join('')}
          </div>
        `;
        
        // 記事カードのホバー効果を追加
        const articleCards = document.querySelectorAll('.article-card');
        articleCards.forEach(card => {
          // ホバー効果
          card.addEventListener('mouseenter', () => {
            card.style.transform = 'translateY(-2px)';
            card.style.boxShadow = '0 4px 12px rgba(0, 0, 0, 0.1)';
            card.style.borderColor = '#999';
          });
          
          card.addEventListener('mouseleave', () => {
            card.style.transform = 'translateY(0)';
            card.style.boxShadow = 'none';
            card.style.borderColor = '#ddd';
          });
        });
      }
    }
    
    // ナビゲーションボタンのホバー効果
    const navButtons = document.querySelectorAll('.nav-button');
    navButtons.forEach(button => {
      if (!button.classList.contains('active')) {
        button.addEventListener('mouseenter', () => {
          button.style.backgroundColor = '#f0f0f0';
        });
        button.addEventListener('mouseleave', () => {
          button.style.backgroundColor = '';
        });
      }
    });
    
    // タブクリックイベント
    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        tabButtons.forEach(btn => {
          btn.style.borderBottom = '1px solid #eee';
          btn.classList.remove('active');
        });
        
        button.style.borderBottom = '2px solid black';
        button.classList.add('active');
        
        currentFilter = button.dataset.filter;
        filterArticles();
      });
    });
    
    
    // モバイル用タブ変更イベント
    if (mobileTabSelector) {
      mobileTabSelector.addEventListener('change', () => {
        const selectedFilter = mobileTabSelector.value;
        
        // PC側のタブボタンも同期
        tabButtons.forEach(btn => {
          btn.style.borderBottom = '1px solid #eee';
          btn.classList.remove('active');
        });
        
        const activeButton = document.querySelector(`[data-filter="${selectedFilter}"]`);
        if (activeButton) {
          activeButton.style.borderBottom = '2px solid black';
          activeButton.classList.add('active');
        }
        
        currentFilter = selectedFilter;
        filterArticles();
      });
    }
    
    // 日付選択イベントリスナー
    function setupDatePickers() {
      // 初期値設定
      const todayStr = formatDateKey(currentDate);
      desktopDatePicker.value = todayStr;
      mobileDatePicker.value = todayStr;
      
      // min/max設定
      desktopDatePicker.min = minDateStr;
      desktopDatePicker.max = maxDateStr;
      mobileDatePicker.min = minDateStr;
      mobileDatePicker.max = maxDateStr;
      
      // PC用日付選択イベント
      desktopDatePicker.addEventListener('change', (e) => {
        const selectedDate = e.target.value;
        currentDate = new Date(selectedDate);
        
        // モバイル側も同期
        mobileDatePicker.value = selectedDate;
        
        // 記事をフィルター
        filterArticles();
      });
      
      // モバイル用日付選択イベント
      mobileDatePicker.addEventListener('change', (e) => {
        const selectedDate = e.target.value;
        currentDate = new Date(selectedDate);
        
        // PC側も同期
        desktopDatePicker.value = selectedDate;
        
        // 記事をフィルター
        filterArticles();
      });
    }
    
    // 初期化処理
    function initialize() {
      // 日付ピッカーの設定
      setupDatePickers();
      
      // モバイル用タブセレクターの初期化
      if (mobileTabSelector) {
        mobileTabSelector.value = currentFilter;
      }
      
      // 初期記事表示
      filterArticles();
    }
    
    // 初期表示
    initialize();
  </script>
</Layout>